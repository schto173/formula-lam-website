DB_NAME=ecomarathon
DB_USER=ecomarathon
DB_PASS=change-me-to-a-strong-password

APP_PORT=3000

# Random string used to sign admin login sessions - generate with:
#   openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created/updated automatically on container start.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password
